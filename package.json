{
  "name": "joyful-brutalist-minimalism",
  "version": "0.1.0",
  "private": true,
  "description": "Sergio's authored design language: constitution, portable tokens, Figma mappings, and coded specimens.",
  "type": "module",
  "scripts": {
    "build": "npm run generate:check && astro check && astro build",
    "check": "npm run format:check && npm run validate:tokens && npm run generate:check && npm run typecheck && npm test",
    "dev": "astro dev",
    "format:check": "node scripts/check-format.mjs",
    "generate": "node scripts/generate-tokens.mjs",
    "generate:check": "node scripts/generate-tokens.mjs --check",
    "preview": "astro preview",
    "serve:test": "node scripts/serve-static.mjs",
    "test": "node --test",
    "test:browser": "playwright test",
    "test:browser:update": "playwright test --update-snapshots",
    "typecheck": "astro check",
    "validate:spec": "uvx check-jsonschema --schemafile https://www.designtokens.org/schemas/2025.10/format.json tokens/jbm.tokens.json",
    "validate:tokens": "node scripts/validate-tokens.mjs",
    "verify": "npm run check && npm run build && npm run test:browser"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/source-serif-4": "^5.2.9",
    "astro": "^7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  }
}
