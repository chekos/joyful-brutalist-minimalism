---
import "@fontsource/source-serif-4/400.css";
import "@fontsource/source-serif-4/600.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteMast from "../components/SiteMast.astro";
import { principles } from "../content/constitution";
import "../styles/tokens.css";
import "../styles/site.css";

const colors = [
  { name: "Page", token: "surface.page", className: "page" },
  { name: "Paper", token: "surface.paper", className: "paper" },
  { name: "Quiet", token: "surface.quiet", className: "quiet" },
  { name: "Ink", token: "text.primary", className: "ink" },
  { name: "Accent field", token: "accent.field", className: "accent-field" },
  { name: "Accent default", token: "accent.default", className: "accent-default" },
  { name: "Accent strong", token: "accent.strong", className: "accent-strong" },
] as const;

const colorways = [
  { name: "terra", tone: "400", note: "default" },
  { name: "sage", tone: "200", note: "alternate" },
  { name: "sky", tone: "200", note: "alternate" },
] as const;

const authorities = [
  {
    className: "meaning",
    owner: "Meaning",
    artifact: "The principles",
    detail: "intent · judgment · reasons",
  },
  {
    className: "materials",
    owner: "Materials",
    artifact: "The foundations",
    detail: "color · type · rules",
  },
  {
    className: "composition",
    owner: "Composition",
    artifact: "The page",
    detail: "hierarchy · measure · rhythm",
  },
  {
    className: "behavior",
    owner: "Behavior",
    artifact: "The interaction",
    detail: "responsive · keyboard · motion",
  },
] as const;

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
---

<!doctype html>
<html lang="en" data-jbm-colorway="terra">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Joyful Brutalist Minimalism is Sergio's authored design language: editorial warmth, technical precision, and useful delight."
    />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#fffef9" />
    <title>Joyful Brutalist Minimalism</title>
    <script is:inline>
      document.documentElement.classList.add("has-js");
    </script>
  </head>
  <body data-jbm-form="ground">
    <a class="skip-link" href="#main-content">Skip to the language</a>

    <SiteMast />

    <div class="page-shell" id="top">
      <main id="main-content" tabindex="-1">
        <section class="hero" aria-labelledby="hero-title">
          <p class="kicker signal" data-jbm-form="kicker">An authored practice for the web</p>
          <h1 id="hero-title">Joyful<br />Brutalist<br />Minimalism</h1>
          <div class="hero-thesis">
            <p class="hero-lede">
              Show how the thing works, give the content room to speak, and attach
              one restrained moment of joy to something useful.
            </p>
            <p>
              This is Sergio's working language for pairing editorial warmth with
              technical precision. It is a practice to interpret, not a framework
              every project must install.
            </p>
          </div>
          <div class="hero-actions">
            <a class="action-link" data-jbm-form="action-link" href="/constitution/">
              Read the constitution <span aria-hidden="true">→</span>
            </a>
          </div>
        </section>

        <aside class="reading-instrument" aria-labelledby="instrument-heading">
          <div class="instrument-head">
            <p class="kicker" data-jbm-form="kicker">Principle index</p>
            <h2 id="instrument-heading">Eight principles.</h2>
            <p class="instrument-summary">
              Jump straight to the part you need.
            </p>
          </div>

          <ol class="instrument-marks" aria-label="Jump to a principle">
            {
              principles.map((principle) => (
                <li>
                  <a
                    class="instrument-mark"
                    href={`#principle-${principle.number}`}
                    data-instrument-mark
                  >
                    <span class="mark-number">{principle.number}</span>
                    <span class="mark-title">{principle.title}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </aside>

        <div class="main-flow">
        <hr class="rule strong" data-jbm-form="rule" />

        <section class="section principles-section" id="principles" aria-labelledby="principles-title">
          <header class="section-intro split-intro">
            <div>
              <p class="kicker" data-jbm-form="kicker">01 / Principles in use</p>
              <h2 id="principles-title">Eight principles decide what belongs.</h2>
            </div>
            <p>
              Use them to test a choice: does it make the work clearer, more
              useful, easier to use, or more memorable?
            </p>
          </header>

          <ol class="principle-ledger">
            {
              principles.map((principle) => (
                <li
                  class="index-row"
                  id={`principle-${principle.number}`}
                  data-principle
                  data-number={principle.number}
                  data-jbm-form="index-row"
                  tabindex="-1"
                >
                  <span class="index-number">{principle.number} / 08</span>
                  <div>
                    <h3>{principle.title}</h3>
                    <p>{principle.summary}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </section>

        <hr class="rule" data-jbm-form="rule" />

        <section class="section" id="foundations" aria-labelledby="foundations-title">
          <header class="section-intro split-intro">
            <div>
              <p class="kicker" data-jbm-form="kicker">02 / Portable foundations</p>
              <h2 id="foundations-title">Named matter, not a mood board.</h2>
            </div>
            <p>
              Color, type, rules, and paper depth come from named roles. The
              browser consumes generated values rather than a second hand-edited
              palette.
            </p>
          </header>

          <div class="foundation-grid">
            <article class="plate color-plate" data-jbm-form="plate">
              <header>
                <p class="kicker">Color / choose one family</p>
                <h3>One colorway at a time</h3>
              </header>
              <div class="colorway-preview" data-colorway-preview hidden>
                <div class="colorway-preview-copy">
                  <p id="colorway-preview-label">Preview the deployment colorway</p>
                  <p>
                    Choose a card to change the whole specimen. Terra is the
                    default; Sage and Sky carry the same roles in a different
                    voice.
                  </p>
                </div>
                <div
                  class="colorway-options"
                  role="group"
                  aria-labelledby="colorway-preview-label"
                >
                  {
                    colorways.map((colorway) => (
                      <button
                        type="button"
                        data-colorway-option={colorway.name}
                        aria-pressed={colorway.name === "terra" ? "true" : "false"}
                      >
                        <span class:list={["colorway-card-field", `colorway-card-${colorway.name}`]} aria-hidden="true">
                          <span>JBM</span>
                        </span>
                        <span class="colorway-card-copy">
                          <strong>{colorway.name}</strong>
                          <small>{colorway.tone} / {colorway.note}</small>
                        </span>
                      </button>
                    ))
                  }
                </div>
                <p class="colorway-status" aria-live="polite">
                  Terra colorway active
                </p>
              </div>
              <ul class="swatch-list" aria-label="Semantic color roles">
                {
                  colors.map((color) => (
                    <li class={`swatch swatch-${color.className}`}>
                      <span class="swatch-chip" aria-hidden="true" />
                      <span>{color.name}</span>
                      <code>{color.token}</code>
                    </li>
                  ))
                }
              </ul>
            </article>

            <article class="plate type-plate" data-jbm-form="plate">
              <header>
                <p class="kicker">Typography / role before family</p>
                <h3>Two voices, one artifact</h3>
              </header>
              <blockquote>Reading should feel warm, calm, and unhurried.</blockquote>
              <p class="type-instrument">MEASURE / PROVENANCE / STATUS</p>
              <p class="type-note">
                Source Serif 4 carries the editorial voice. IBM Plex Mono makes
                compact evidence align and scan.
              </p>
            </article>

            <article class="plate pressure-plate" data-jbm-form="plate">
              <header>
                <p class="kicker">Shape / depth / movement</p>
                <h3>Pressure, never gloss</h3>
              </header>
              <figure class="pressure-samples">
                <figcaption class="sr-only">Paper depth samples</figcaption>
                <div class="paper-sample crisp">Crisp offset</div>
                <div class="paper-sample inset">Quiet inset</div>
              </figure>
              <p>
                Rules stay at one or two pixels, paper corners stay nearly square,
                and explanatory motion resolves to zero when reduced motion is set.
              </p>
            </article>
          </div>
        </section>

        <hr class="rule" data-jbm-form="rule" />

        <section
          class="section marginalia-section"
          id="marginalia"
          aria-labelledby="marginalia-title"
          data-jbm-study="contextual-marginalia"
        >
          <header class="section-intro split-intro">
            <div>
              <p class="kicker signal" data-jbm-form="kicker">03 / Browser study</p>
              <h2 id="marginalia-title">Keep context close to the sentence.</h2>
            </div>
            <p>
              Contextual Marginalia keeps short explanations beside the
              paragraph they belong to. Hover, focus, or follow a marked term
              to read its note.
            </p>
          </header>

          <figure class="marginalia-study">
            <div class="marginalia-reading">
              <article class="marginalia-article" aria-labelledby="marginalia-article-title">
                <p class="study-status">FIELD NOTE · READING ON THE WEB</p>
                <h3 id="marginalia-article-title">A quiet page still has structure.</h3>
                <p>
                  Calm does not come from removing information. It comes from
                  giving each idea a clear place to land.
                </p>
                <p class="marginalia-passage">
                  A comfortable{" "}
                  <a
                    class="marginalia-term"
                    href="#contextual-note-01"
                    data-note-trigger="01"
                    aria-describedby="contextual-note-copy-01"
                  >
                    <strong>reading measure</strong><sup aria-hidden="true">01</sup><span class="sr-only">
                      , annotation 1</span
                    >
                  </a>
                  {" "}helps the eye return to the next line. A{" "}
                  <a
                    class="marginalia-term"
                    href="#contextual-note-02"
                    data-note-trigger="02"
                    aria-describedby="contextual-note-copy-02"
                  >
                    <strong>deliberate pause</strong><sup aria-hidden="true">02</sup><span class="sr-only">
                      , annotation 2</span
                    >
                  </a>
                  {" "}marks a real change in subject without turning every
                  thought into a card.
                </p>
                <p>
                  The structure is visible, but the paragraph remains the thing
                  you came to read.
                </p>
              </article>
              <p class="study-instruction">
                Hover or focus a marked term. On narrow screens, both notes
                follow the article in reading order.
              </p>
            </div>

            <aside class="marginalia-sidecar" aria-label="Annotations for the study passage">
              <div class="marginalia-register" aria-hidden="true">
                <div class="register-head">
                  <span>Annotation register</span>
                  <strong>02 terms</strong>
                </div>
                <ol>
                  <li>
                    <span>01</span>
                    <strong>Reading measure</strong>
                  </li>
                  <li>
                    <span>02</span>
                    <strong>Deliberate pause</strong>
                  </li>
                </ol>
              </div>

              <ol class="marginal-notes">
                <li class="marginal-note" id="contextual-note-01" data-note="01">
                  <span class="note-number">01</span>
                  <div>
                    <strong>Reading measure</strong>
                    <p id="contextual-note-copy-01">
                      The width of a line of text. A comfortable measure helps
                      readers follow a line and find the start of the next one.
                    </p>
                  </div>
                </li>
                <li class="marginal-note" id="contextual-note-02" data-note="02">
                  <span class="note-number">02</span>
                  <div>
                    <strong>Deliberate pause</strong>
                    <p id="contextual-note-copy-02">
                      Space tied to a real change in subject or emphasis. It
                      gives the reader a breath and makes the hierarchy visible.
                    </p>
                  </div>
                </li>
              </ol>
            </aside>

            <figcaption class="study-caption">
              <span>STUDY · NOT YET PROMOTED</span>
              <strong>The explanation stays beside the paragraph and appears when it is useful.</strong>
              <small>
                PROVENANCE · Interaction contract studied from{" "}
                <a href="https://www.makingsoftware.com/chapters/how-to-make-a-font">Making Software</a>
                {" "}· Original JBM wording, geometry, and motion
              </small>
            </figcaption>
          </figure>
        </section>

        <hr class="rule" data-jbm-form="rule" />

        <section class="section figure-section" id="figure" aria-labelledby="figure-title">
          <header class="section-intro split-intro">
            <div>
              <p class="kicker signal" data-jbm-form="kicker">04 / Practice in motion</p>
              <h2 id="figure-title">One idea. Four ways it shows up.</h2>
            </div>
            <p>
              A design choice should agree in its meaning, materials,
              composition, and behavior. Each view tests whether the idea
              survives beyond a single screen.
            </p>
          </header>

          <figure class="technical-figure">
            <div
              class="authority-map"
              role="img"
              aria-describedby="figure-equivalent figure-caption"
              aria-label="A design idea is named by its intent, then tested through meaning, materials, composition, and behavior."
            >
              <div class="authority-step authority-step-change">
                <span>01 / Start with intent</span>
                <strong>Name what the choice should help someone understand or do.</strong>
              </div>
              <ol class="authority-grid">
                {
                  authorities.map((authority, index) => (
                    <li class={`authority-node authority-${authority.className}`}>
                      <span>{String(index + 1).padStart(2, "0")} / {authority.owner}</span>
                      <strong>{authority.artifact}</strong>
                      <small>{authority.detail}</small>
                    </li>
                  ))
                }
              </ol>
              <div class="authority-step authority-step-check">
                <span>02 / Test the whole</span>
                <strong>Read it · see it · use it · revisit it in another context</strong>
              </div>
            </div>
            <p class="sr-only" id="figure-equivalent">
              Begin by naming what a choice should help someone understand or
              do. Then test whether that intent remains clear in the principles,
              the visual materials, the composition of the page, and the
              behavior of the interaction.
            </p>
            <figcaption class="figure-caption" id="figure-caption" data-jbm-form="figure-caption">
              <span>FIG. 01</span>
              <strong>A strong idea survives translation into content, form, and behavior.</strong>
              <small>PRACTICE NOTE · Test the same intent from more than one point of view</small>
            </figcaption>
          </figure>
        </section>
        </div>
      </main>
    </div>

    <SiteFooter />

    <script is:inline>
      const preview = document.querySelector("[data-colorway-preview]");
      const options = document.querySelectorAll("[data-colorway-option]");
      const status = preview?.querySelector(".colorway-status");

      if (preview instanceof HTMLElement && status instanceof HTMLElement) {
        preview.hidden = false;
        options.forEach((option) => {
          if (!(option instanceof HTMLButtonElement)) return;
          option.addEventListener("click", () => {
            const colorway = option.dataset.colorwayOption;
            if (!colorway) return;

            document.documentElement.dataset.jbmColorway = colorway;
            options.forEach((candidate) => {
              candidate.setAttribute(
                "aria-pressed",
                String(candidate === option),
              );
            });
            status.textContent = `${colorway[0].toUpperCase()}${colorway.slice(1)} colorway active`;
          });
        });
      }
    </script>
  </body>
</html>
